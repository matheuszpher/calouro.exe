  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NpcInteractable
  npcName: Emilly
  npcId: emilly
  lines:
  - "Oi! Eu sou a Emilly, tamb\xE9m sou caloura."
  - "Cara, t\xF4 boiando numa lista de exerc\xEDcios... tava vendo se algu\xE9m me
    dava uma luz."
  objectiveLines: []
  repeatLines:
  - lines:
    - "Oi de novo! Como est\xE3o as mat\xE9rias?"
  - lines:
    - Valeu por aquela ajuda com a lista, hein.
  hasChoice: 1
  choiceQuestion: "Voc\xEA para pra ajudar a Emilly com a lista?"
  choiceOptionA: Claro, bora resolver junto!
  choiceOptionB: "Agora n\xE3o d\xE1, foi mal."
  choiceReplyA: "S\xE9rio? Valeu demais! Assim o primeiro dia fica bem melhor."
  choiceReplyB: Ah... tranquilo, depois eu vejo. Boa aula!
  ethicsRewardA: 1
  ethicsRewardB: 0
  examObjective: 
  examKind: 
  examLines: []
