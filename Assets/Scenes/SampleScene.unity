  m_Script: {fileID: 11500000, guid: 38b2b004f50d33f4eb1e6416e7a913cc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NpcInteractable
  npcName: Matheus
  npcId: aluno_matheus
  lines:
  - "E a\xED, calouro! Tudo certo pras provas?"
  - "Cara, t\xF4 travado num exerc\xEDcio de revis\xE3o e as provas s\xE3o j\xE1
    j\xE1..."
  objectiveLines: []
  repeatLines:
  - lines:
    - "E a\xED! Valeu de novo por aquela ajuda."
  - lines:
    - "Bora, ainda tenho mais exerc\xEDcios pra revisar depois."
  hasChoice: 1
  choiceQuestion: "Voc\xEA senta pra revisar o exerc\xEDcio junto com o Matheus?"
  choiceOptionA: Bora, a gente resolve isso.
