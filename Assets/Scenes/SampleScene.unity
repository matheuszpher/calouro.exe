MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 625131843}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 38b2b004f50d33f4eb1e6416e7a913cc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NpcInteractable
  npcName: Natan
  npcId: natan
  lines:
  - "E a\xED, calouro! Eu sou o Natan."
  - "As primeiras provas t\xE3o chegando... Matem\xE1tica no labirinto, o quiz do
    Jeferson, aquele problema de FUP..."
  - "T\xF4 montando um resum\xE3o aqui no RU. Cola comigo que a gente revisa junto."
  objectiveLines: []
  repeatLines:
  - lines:
    - Fala, calouro! Bons estudos.
  - lines:
    - "Se precisar revisar de novo, s\xF3 chamar."
  hasChoice: 1
  choiceQuestion: Estudar em grupo pra reta final antes das provas?
  choiceOptionA: Bora! Junto rende mais.
  choiceOptionB: Prefiro revisar sozinho.
  choiceReplyA: "Isso! Duas cabe\xE7as pensam melhor. J\xE1 j\xE1 voc\xEA t\xE1 afiado."
  choiceReplyB: "De boa, cada um no seu ritmo. Qualquer d\xFAvida, t\xF4 aqui."
  ethicsRewardA: 1
  ethicsRewardB: 0
  examObjective: 
  examKind: 
  examLines: []
