  m_Script: {fileID: 11500000, guid: 38b2b004f50d33f4eb1e6416e7a913cc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NpcInteractable
  npcName: Yasmin
  npcId: yasmin
  lines:
  - "Oi! Voc\xEA tamb\xE9m t\xE1 tentando decorar o mapa do campus?"
  - Eu ainda me perco tentando achar o Bloco 4.
  objectiveLines: []
  repeatLines:
  - lines:
    - "Oi de novo! Ainda t\xF4 decorando esse mapa do campus, viu."
  - lines:
    - "E a\xED! Achou o Bloco 4 mais f\xE1cil de achar agora?"
  hasChoice: 1
  choiceQuestion: "Ela te pede uma ajuda com a lista de FUP. Voc\xEA ajuda?"
  choiceOptionA: Claro, bora ver isso.
  choiceOptionB: "Agora n\xE3o, t\xF4 sem tempo."
  choiceReplyA: "A\xEA! Voc\xEA me salvou. Depois te pago um caf\xE9."
  choiceReplyB: Tranquilo, depois eu tento de novo. Valeu mesmo assim!
  ethicsRewardA: 1
  ethicsRewardB: 0
  examObjective: 
  examKind: 
  examLines: []
