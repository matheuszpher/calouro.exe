  m_Script: {fileID: 11500000, guid: 38b2b004f50d33f4eb1e6416e7a913cc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NpcInteractable
  npcName: Jeferson
  npcId: jeferson_prova
  lines:
  - "Opa! Al\xE9m de coordenador, eu tamb\xE9m sou professor de Introdu\xE7\xE3o
    \xE0 Engenharia de Software."
  - "A prova de IES acontece aqui nesta sala, no per\xEDodo de avalia\xE7\xF5es."
  objectiveLines: []
  repeatLines:
  - lines:
    - "Opa, calouro! Como est\xE1 se adaptando ao curso?"
    - "Engenharia de Software \xE9 sobre processo \u2014 n\xE3o esquece disso."
  - lines:
    - "Precisando de alguma orienta\xE7\xE3o? Pode perguntar."
    - Bora focar no resto do semestre.
  hasChoice: 0
  choiceQuestion: 
  choiceOptionA: 
  choiceOptionB: 
  choiceReplyA: 
  choiceReplyB: 
  ethicsRewardA: 0
  ethicsRewardB: 0
  examObjective: prova_ies
  examKind: ies
  examLines:
  - "Chegou a prova de Introdu\xE7\xE3o \xE0 Engenharia de Software!"
  - "S\xE3o algumas perguntas objetivas sobre os conceitos que a gente viu. Responde
    com calma."
