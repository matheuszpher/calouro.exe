--- !u!114 &1873811059
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1873811057}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 38b2b004f50d33f4eb1e6416e7a913cc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NpcInteractable
  npcName: Enzo
  npcId: enzo
  lines:
  - "E a\xED! Sou o Enzo, do Bloco 4."
  - "Perdi a aula de ontem e t\xF4 sem o material... tava vendo se algu\xE9m me empresta
    as anota\xE7\xF5es."
  objectiveLines: []
  repeatLines:
  - lines:
    - "E a\xED! Valeu de novo pelas anota\xE7\xF5es."
  - lines:
    - Oi! Bloco 4 continua um labirinto pra mim, confesso.
  hasChoice: 1
  choiceQuestion: "Voc\xEA empresta suas anota\xE7\xF5es pro Enzo?"
  choiceOptionA: Claro, te mando tudo hoje!
  choiceOptionB: Ah, eu ainda preciso delas.
  choiceReplyA: Mano, salvou demais! Semana que vem eu te retribuo.
  choiceReplyB: Sem problema, eu me viro. Valeu mesmo assim!
  ethicsRewardA: 1
  ethicsRewardB: 0
  examObjective: 
  examKind: 
  examLines: []
